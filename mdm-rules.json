{
  "version": "1",
  "mdmTypes": ["Patient"],

  "candidateSearchParams": [
    {
      "resourceType": "Patient",
      "searchParams": ["identifier"]
    },
    {
      "resourceType": "Patient",
      "searchParams": ["family", "birthdate"]
    },
    {
      "resourceType": "Patient",
      "searchParams": ["name", "birthdate"]
    }
  ],

  "candidateFilterSearchParams": [],

  "matchFields": [
    {
      "name": "philhealth-id",
      "resourceType": "Patient",
      "matcher": {
        "algorithm": "IDENTIFIER"
      },
      "fhirPath": "Patient.identifier.where(system='https://philhealth.gov.ph')"
    },

    {
      "name": "national-id",
      "resourceType": "Patient",
      "matcher": {
        "algorithm": "IDENTIFIER"
      },
      "fhirPath": "Patient.identifier.where(system='https://psa.gov.ph/philid')"
    },

    {
      "name": "facility-mrn",
      "resourceType": "Patient",
      "matcher": {
        "algorithm": "IDENTIFIER"
      },
      "fhirPath": "Patient.identifier.where(system='http://hospital.smarthealth.org/mrn')"
    },

    {
      "name": "family-name",
      "resourceType": "Patient",
      "resourcePath": "name.family"
    },

    {
      "name": "given-name",
      "resourceType": "Patient",
      "resourcePath": "name.given"
    },

    {
      "name": "birthdate",
      "resourceType": "Patient",
      "resourcePath": "birthDate"
    },

    {
      "name": "sex",
      "resourceType": "Patient",
      "resourcePath": "gender"
    }
  ],


  "matchResultMap": {

    "philhealth-id": "MATCH",

    "national-id": "MATCH",

    "facility-mrn": "MATCH",


    "family-name,birthdate": "POSSIBLE_MATCH",

    "given-name,family-name,birthdate": "POSSIBLE_MATCH",

    "family-name,given-name,birthdate": "POSSIBLE_MATCH",

    "family-name,given-name,birthdate,gender": "POSSIBLE_MATCH",


    "family-name": "NO_MATCH",

    "given-name": "NO_MATCH"

  },


  "eidSystems": {
    "Patient": "https://philhealth.gov.ph"
  }
}