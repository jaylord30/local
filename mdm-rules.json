{
  "version": "1",
  "mdmTypes": ["Patient"],

  "candidateSearchParams": [
    {
      "resourceType": "Patient",
      "searchParams": ["identifier"]
    },
    {
      "resourceType": "Patient",
      "searchParams": ["family", "birthdate"]
    }
  ],

  "candidateFilterSearchParams": [],

  "matchFields": [
    {
      "name": "mrn-exact",
      "resourceType": "Patient",
      "matcher": {
        "algorithm": "IDENTIFIER"
      },
      "fhirPath": "Patient.identifier.where(system='http://hospital.smarthealth.org/mrn')"
    },

    {
      "name": "national-id",
      "resourceType": "Patient",
      "matcher": {
        "algorithm": "IDENTIFIER"
      },
      "fhirPath": "Patient.identifier"
    },

    {
      "name": "family-name",
      "resourceType": "Patient",
      "resourcePath": "name.family"
    },

    {
      "name": "given-name",
      "resourceType": "Patient",
      "resourcePath": "name.given"
    },

    {
      "name": "birthdate",
      "resourceType": "Patient",
      "resourcePath": "birthDate"
    },

    {
      "name": "gender",
      "resourceType": "Patient",
      "resourcePath": "gender"
    }
  ],

  "matchResultMap": {
    "mrn-exact": "MATCH",
    "national-id": "MATCH",

    "family-name,birthdate": "POSSIBLE_MATCH",
    "given-name,family-name,birthdate": "POSSIBLE_MATCH",

    "family-name,given-name,birthdate": "POSSIBLE_MATCH",

    "family-name": "NO_MATCH",
    "given-name": "NO_MATCH"
  },

  "eidSystems": {
    "Patient": "http://hospital.smarthealth.org/mrn"
  }
}
